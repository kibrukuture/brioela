{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@schnl/shared/*": ["../shared/*"],
      "zod/v4": ["../shared/zod/v4"]
