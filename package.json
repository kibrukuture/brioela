{
  "name": "brioela",
  "private": true,
  "type": "module",
  "scripts": {
    "name:check": "BRIOELA_WORKSPACE_ROOT=$PWD bun --cwd tools/brioela-name-guard check",
    "name:watch": "BRIOELA_WORKSPACE_ROOT=$PWD bun --cwd tools/brioela-name-guard watch",
    "name:baseline:update": "BRIOELA_WORKSPACE_ROOT=$PWD bun --cwd tools/brioela-name-guard baseline:update",
    "name:daemon:install": "BRIOELA_WORKSPACE_ROOT=$PWD bun --cwd tools/brioela-name-guard daemon:install",
    "name:daemon:uninstall": "BRIOELA_WORKSPACE_ROOT=$PWD bun --cwd tools/brioela-name-guard daemon:uninstall",
    "name:daemon:start": "BRIOELA_WORKSPACE_ROOT=$PWD bun --cwd tools/brioela-name-guard daemon:start",
    "name:daemon:stop": "BRIOELA_WORKSPACE_ROOT=$PWD bun --cwd tools/brioela-name-guard daemon:stop",
    "name:daemon:status": "BRIOELA_WORKSPACE_ROOT=$PWD bun --cwd tools/brioela-name-guard daemon:status",
    "name:daemon:print": "BRIOELA_WORKSPACE_ROOT=$PWD bun --cwd tools/brioela-name-guard daemon:print",
    "name:logs": "BRIOELA_WORKSPACE_ROOT=$PWD bun --cwd tools/brioela-name-guard logs",
    "name:logs:err": "BRIOELA_WORKSPACE_ROOT=$PWD bun --cwd tools/brioela-name-guard logs:err",
    "name:logs:out": "BRIOELA_WORKSPACE_ROOT=$PWD bun --cwd tools/brioela-name-guard logs:out",
    "type:guard": "BRIOELA_WORKSPACE_ROOT=$PWD bun --cwd tools/brioela-type-guard check",
    "type:guard:watch": "BRIOELA_WORKSPACE_ROOT=$PWD bun --cwd tools/brioela-type-guard watch",
    "type:guard:baseline:update": "BRIOELA_WORKSPACE_ROOT=$PWD bun --cwd tools/brioela-type-guard baseline:update",
    "type:daemon:start": "BRIOELA_WORKSPACE_ROOT=$PWD bun --cwd tools/brioela-type-guard daemon:start",
    "type:daemon:stop": "BRIOELA_WORKSPACE_ROOT=$PWD bun --cwd tools/brioela-type-guard daemon:stop",
    "type:daemon:status": "BRIOELA_WORKSPACE_ROOT=$PWD bun --cwd tools/brioela-type-guard daemon:status",
    "type:daemon:print": "BRIOELA_WORKSPACE_ROOT=$PWD bun --cwd tools/brioela-type-guard daemon:print",
    "type:logs": "BRIOELA_WORKSPACE_ROOT=$PWD bun --cwd tools/brioela-type-guard logs",
    "type:logs:err": "BRIOELA_WORKSPACE_ROOT=$PWD bun --cwd tools/brioela-type-guard logs:err",
    "type:logs:out": "BRIOELA_WORKSPACE_ROOT=$PWD bun --cwd tools/brioela-type-guard logs:out",
    "name:start": "bun run name:daemon:start",
    "name:stop": "bun run name:daemon:stop",
    "name:restart": "bun run name:stop && bun run name:start",
    "name:status": "bun run name:daemon:status",
    "type:start": "bun run type:daemon:start",
    "type:stop": "bun run type:daemon:stop",
    "type:restart": "bun run type:stop && bun run type:start",
    "type:status": "bun run type:daemon:status",
    "check:names": "bun run name:check",
    "watch:names": "bun run name:watch",
    "check:types": "bun run type:guard",
    "watch:types": "bun run type:guard:watch",
    "update:name-baseline": "bun run name:baseline:update",
    "update:type-baseline": "bun run type:guard:baseline:update",
    "install:name-daemon": "bun run name:daemon:install",
    "uninstall:name-daemon": "bun run name:daemon:uninstall",
    "status:name-daemon": "bun run name:daemon:status",
    "verify": "bun run check:names && bun run check:types",
    "deploy:backend": "fly deploy -c backend/fly.toml",
    "deploy:pdf-converter": "fly deploy -c pdf-converter/fly.toml",
    "deploy:universal-file-converter": "fly deploy -c universal-file-converter/fly.toml",
    "deploy": "bun run deploy:backend && bun run deploy:pdf-converter && bun run deploy:universal-file-converter",
    "build:machine-bootstrap": "tsc -p scripts/tsconfig.json"
  },
  "workspaces": [
    "backend",
    "shared",
    "mobile",
    "tools/brioela-name-guard"
    ,"tools/brioela-type-guard"
  ],
  "packageManager": "bun@1.2.21",
  "dependencies": {
    "dotenv": "^17.4.2"
  },
  "trustedDependencies": [
    "@shopify/react-native-skia"
  ]
}
