{
  "name": "@brioela/name-guard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "brioela-name-guard": "./run.brioela.name.guard.handler.ts"
  },
  "scripts": {
    "check": "bun run.brioela.name.guard.handler.ts",
    "watch": "bun run.brioela.name.guard.handler.ts --watch",
    "baseline:update": "bun run.brioela.name.guard.handler.ts --update-baseline",
    "daemon:install": "bun install.name.guard.daemon.handler.ts",
    "daemon:uninstall": "bun uninstall.name.guard.daemon.handler.ts",
    "daemon:start": "bun start.name.guard.daemon.handler.ts",
    "daemon:stop": "bun stop.name.guard.daemon.handler.ts",
    "daemon:status": "bun status.name.guard.daemon.handler.ts",
    "daemon:print": "bun print.name.guard.daemon.handler.ts",
    "logs": "bun tail.name.guard.logs.handler.ts",
    "logs:err": "bun tail.name.guard.logs.handler.ts err",
    "logs:out": "bun tail.name.guard.logs.handler.ts out",
    "typecheck": "bunx tsc --noEmit --pretty false"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^5.9.3"
  }
}
