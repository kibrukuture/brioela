#!/bin/sh
# Brioela gate wall — fail closed.
# A commit lands only with a live daemon, a clean board, and a signed receipt
# matching this exact staged diff. No daemon = red. Red = no commit.
BRIOELA_WORKSPACE_ROOT="$(git rev-parse --show-toplevel)" \
  exec bun --cwd "$(git rev-parse --show-toplevel)/tools/brioela-reading-gate" verdict --receipt
